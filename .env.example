# Backend API Configuration
# Default PORT is 5000. For Vercel, this is usually set by the platform.
# PORT=5000
# DEBUG=True

# Frontend Configuration
# API_URL should be the full URL to the backend (no trailing slash)
# Locally: http://localhost:5000
# Vercel: https://your-backend.vercel.app/api
API_URL=http://localhost:5000

# Optional Model Directory override
# MODEL_DIR=model
